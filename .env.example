# Copy to .env.local and adjust. Used by Next.js and the Express backend (backend loads this from repo root).

# Public base URL of the Express API. Next.js rewrites /api/* to this host and uses it for server-side content fetch.
BACKEND_URL=http://127.0.0.1:4000

# Optional: public HTTPS origin of your site (e.g. https://yourdomain.com). Used when uploading a reference image for video so the returned URL is HTTPS and the video API can fetch it. If unset, the API uses request headers (works on many hosts; local http:// often cannot be used for uploads).
# PUBLIC_BASE_URL=https://yourdomain.com

# Optional: override API port for Express only (default 4000).
# BACKEND_PORT=4000

# Optional: absolute path for SQLite + local JSON (default: backend/data next to the API). Use a mounted volume in production.
# DATA_DIR=/var/lib/ruhgen/data

# Signing key for admin JWT sessions (login at /admin/login). Falls back to ADMIN_SECRET if unset.
ADMIN_JWT_SECRET=change-me-in-production

# Legacy fallback for JWT signing if ADMIN_JWT_SECRET is not set.
ADMIN_SECRET=change-me-in-production

# Operator account (SQLite). On each API start: empty DB inserts one row; if exactly one admin
# exists, email/password/name are updated from env so login matches .env after you change it.
# With multiple admins, only the row matching ADMIN_SEED_EMAIL is updated.
# ADMIN_SEED_DISABLE_SYNC=1 — only insert when admins table is empty (do not overwrite).
ADMIN_SEED_EMAIL=admin@ruhgen.local
ADMIN_SEED_PASSWORD=change-me-after-clone
ADMIN_SEED_NAME=Site Admin

# NVIDIA GenAI (ai.api.nvidia.com) — home-page Live studio demo (/#preview), FLUX.2 Klein 4B image generation.
# Use the same nvapi key from build.nvidia.com. Any one of these names works:
# NVIDIA_GENAI_API_KEY=
# NVIDIA_API_KEY=

# PiAPI (https://api.piapi.ai) — single gateway for generation; the app never calls Kling/Flux APIs directly.
# `model` values in requests are PiAPI routing names (e.g. kling-turbo, Qubico/flux1-dev).
# Used only on the Express backend; never exposed to the browser.
PI_API_KEY=
# Alternative name (either works):
# pi_api_key=

# Video: PiAPI video model id (routing only). Default kling-turbo. Legacy: kling.
# STUDIO_KLING_MODEL=kling-turbo
# STUDIO_KLING_MODEL=kling

# Reset local SQLite + JSON under DATA_DIR (and optionally .next): stop dev servers first, then:
# npm run clear:data     — DB files only
# npm run clear:local    — DB + Next.js .next cache
